# Maintainer: MilkmanAbi
# ytcui — versioned source package. This builds from a tagged release tarball.
#
# IMPORTANT: this requires a matching git tag to exist, e.g. `v3.5.5`. The old
# AUR package broke because it referenced `v1.0.0` which was never tagged, so
# GitHub returned 404. Before publishing this, tag and push a release:
#
#     git tag -a v3.5.5 -m "v3.5.5"
#     git push origin v3.5.5
#
# Then bump pkgver below to match and regenerate sha256sums with `updpkgsums`.
pkgname=ytcui
pkgver=3.5.5
pkgrel=1
pkgdesc="Fast terminal YouTube client (ncurses, mpv, built-in ytcui-dl)"
arch=('x86_64' 'aarch64')
url="https://github.com/MilkmanAbi/ytcui"
license=('MIT')
depends=('ncurses' 'curl' 'openssl' 'mpv' 'chafa')
makedepends=('gcc' 'make' 'pkgconf')
optdepends=('libsixel: in-process SIXEL thumbnail encoding (build with SIXEL=libsixel)'
            'yt-dlp: fallback backend (build with BACKEND=ytdlp)')
conflicts=('ytcui-git' 'ytcui-bin')
# The release tarball already contains README.md, LICENSE, etc. — so there is
# no separate raw README fetch, which is what 404'd before.
source=("$pkgname-$pkgver.tar.gz::https://github.com/MilkmanAbi/ytcui/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')   # run `updpkgsums` to fill this in once the tag exists

build() {
    cd "$srcdir/$pkgname-$pkgver"
    make BACKEND=ytcuidl
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    make PREFIX=/usr DESTDIR="$pkgdir" install
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
